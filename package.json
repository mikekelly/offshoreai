{
  "name": "@offshoreai/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Offshore AI — Jersey baseline agent monorepo. Corpus at the root, agent runtime in packages/. See CLAUDE.md and IMPLEMENTATION-PLAN.md.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build:corpus": "pnpm --filter @offshoreai/build run cli",
    "health": "pnpm --filter @offshoreai/build run health",
    "test": "pnpm -r --no-bail test",
    "typecheck": "pnpm -r --no-bail typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "@types/node": "^22.9.0"
  }
}
